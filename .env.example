# Supabase — Variáveis públicas (seguras para commitar)
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxx"
VITE_SUPABASE_URL="https://your_project.supabase.co"

# Supabase — Variáveis de servidor (privadas, NÃO COMMITAR)
SUPABASE_PROJECT_ID="your_project_id"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxx"
SUPABASE_URL="https://your_project.supabase.co"

# ⚠️ OBRIGATÓRIO EM PRODUÇÃO — Copie do Supabase > Settings > API
# Acesso: https://app.supabase.com/project/{project}/settings/api
SUPABASE_SERVICE_ROLE_KEY="sbp_xxxxx_your_service_role_key"

# ⚠️ OBRIGATÓRIO — Gerado para API de inbound email
# Deve ser uma string aleatória forte (min. 32 caracteres)
# Mesmo valor deve ser configurado no serviço de email que chama /api/public/inbound-email
INBOUND_EMAIL_SECRET="generate_a_random_secret_min_32_chars"

# ⚠️ OBRIGATÓRIO — Chave de API do serviço de IA
# Atualmente usado para gerar insights de portfólio (Azure OpenAI ou similar)
LOVABLE_API_KEY="sk-xxxxx_your_api_key"

# ⚠️ OBRIGATÓRIO — Chave de API do Resend para envio de e-mails transacionais
# (confirmação de cadastro, reset de senha, marco atribuído, projeto aprovado/reprovado)
# Gerar em https://resend.com/api-keys com escopo "Sending access"
RESEND_API_KEY="re_xxxxx_your_resend_api_key"

# ⚠️ OBRIGATÓRIO — Remetente dos e-mails transacionais via Resend
# Deve usar um domínio verificado no Resend (Resend → Domains)
# Formato: "Nome <email@dominio>" — ex: "GestorFINEP <naoresponda@mail.SEUDOMINIO.com.br>"
RESEND_FROM_EMAIL="GestorFINEP <naoresponda@mail.SEUDOMINIO.com.br>"

# Opcional — URL base da aplicação, usada para montar links clicáveis nos e-mails
# (ex: link "Ver projeto" nos e-mails de negócio)
# Em produção, usar a URL pública do deploy. Em dev, deixar em branco (fallback a "")
APP_URL="http://localhost:3000"

# Limite máximo de tamanho de arquivo para documentos (em bytes)
# Padrão: 26843545 (25 MB) — apropriado para PDFs e contratos
# Mínimo recomendado: 5242880 (5 MB) — para documentos simples
# Máximo recomendado: 52428800 (50 MB) — para arquivos grandes
MAX_DOCUMENT_SIZE="26843545"

# ⚠️ IMPORTANTE — Segurança de Usuários
# 1. Gestão de usuários é apenas para ADMIN (validado no backend)
# 2. Desativar usuário bloqueia acesso imediatamente (soft delete + RLS)
# 3. Não é possível ficar sem admin (enforçado no trigger do banco)
# 4. Editar usuários requer submeter server function, não acesso direto ao banco

# Opcional — Para debug local
# DEBUG=true
