# Supabase — Variáveis públicas (seguras para commitar)
VITE_SUPABASE_PROJECT_ID="your_project_id"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxx"
VITE_SUPABASE_URL="https://your_project.supabase.co"

# Supabase — Variáveis de servidor (privadas, NÃO COMMITAR)
SUPABASE_PROJECT_ID="your_project_id"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxxxx"
SUPABASE_URL="https://your_project.supabase.co"

# ⚠️ OBRIGATÓRIO EM PRODUÇÃO — Copie do Supabase > Settings > API
# Acesso: https://app.supabase.com/project/{project}/settings/api
SUPABASE_SERVICE_ROLE_KEY="sbp_xxxxx_your_service_role_key"

# ⚠️ OBRIGATÓRIO — Gerado para API de inbound email
# Deve ser uma string aleatória forte (min. 32 caracteres)
# Mesmo valor deve ser configurado no serviço de email que chama /api/public/inbound-email
INBOUND_EMAIL_SECRET="generate_a_random_secret_min_32_chars"

# ⚠️ OBRIGATÓRIO — Chave de API do serviço de IA
# Atualmente usado para gerar insights de portfólio (Azure OpenAI ou similar)
LOVABLE_API_KEY="sk-xxxxx_your_api_key"

# Opcional — Para debug local
# DEBUG=true
